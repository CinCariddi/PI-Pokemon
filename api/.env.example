# Local development: connect with separate credentials, no SSL.
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pokemon

# Production (Neon, Supabase, ...): a single connection string, SSL enabled.
# When DATABASE_URL is set it takes precedence over the variables above.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

PORT=3001

# Comma-separated list of origins allowed to call the API.
CORS_ORIGIN=http://localhost:3000
